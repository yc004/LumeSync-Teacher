{
  "appId": "com.lumesync.teacher",
  "productName": "LumeSync Teacher",
  "copyright": "Copyright © 2024",
  "electronVersion": "29.4.6",
  "directories": {
    "output": "../../dist/teacher",
    "buildResources": "shared/build",
    "app": "."
  },
  "files": [
    "package.json",
    {
      "from": "electron",
      "to": "electron"
    },
    {
      "from": "server",
      "to": "server"
    },
    {
      "from": "public",
      "to": "public"
    },
    {
      "from": "shared/public",
      "to": "shared/public"
    },
    {
      "from": "shared/build",
      "to": "shared/build"
    },
    {
      "from": "shared/assets",
      "to": "shared/assets"
    },
    {
      "from": "packages/engine",
      "to": "packages/engine"
    },
    {
      "from": "packages/runtime-control",
      "to": "packages/runtime-control"
    },
    {
      "from": "packages/render-engine",
      "to": "packages/render-engine"
    },
    {
      "from": "common",
      "to": "common"
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "asar": false,
  "npmArgs": [
    "--workspaces=false"
  ],
  "fileAssociations": [
    {
      "ext": "lume",
      "name": "LumeSync 课件",
      "description": "LumeSync 互动课件文件",
      "icon": "shared/build/icon-course.ico"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "shared/build/icon-teacher.ico",
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "installerLanguages": [
      "zh_CN"
    ],
    "language": "2052",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "LumeSync Teacher",
    "installerIcon": "shared/build/icon-teacher.ico",
    "uninstallerIcon": "shared/build/icon-teacher.ico",
    "installerHeaderIcon": "shared/build/icon-teacher.ico",
    "deleteAppDataOnUninstall": false
  }
}
