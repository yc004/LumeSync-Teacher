<Window x:Class="LumeSyncTeacherInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LumeSync Teacher 安装程序"
        Width="840"
        Height="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
  <Border Background="#0F172A" CornerRadius="14" BorderBrush="#1E293B" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="52" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="#111C37" CornerRadius="14,14,0,0">
        <Grid>
          <TextBlock Margin="20,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="#E2E8F0"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Text="LumeSync Teacher 安装程序" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,12,0">
            <Button Name="MinButton" Content="-" Width="36" Height="28" Margin="0,0,8,0"
                    Background="#1E293B" BorderBrush="#1E293B" Click="MinButton_Click" />
            <Button Name="CloseButton" Content="X" Width="36" Height="28"
                    Background="#7F1D1D" BorderBrush="#7F1D1D" Click="CloseButton_Click" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" Margin="26">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#F8FAFC"
                   Text="LumeSync Teacher" />

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   FontSize="17"
                   Foreground="#93C5FD"
                   Text="现代化课堂控制安装程序" />

        <Border Grid.Row="2" Margin="0,28,0,0" Background="#131F3E" CornerRadius="10" Padding="18">
          <StackPanel>
            <TextBlock Foreground="#E2E8F0" FontSize="14" FontWeight="SemiBold" Text="安装位置" />
            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox Name="InstallPathTextBox"
                       Height="40"
                       VerticalContentAlignment="Center"
                       FontSize="13"
                       Padding="10,0"
                       Background="#0B1224"
                       BorderBrush="#334155"
                       Foreground="#E2E8F0" />
              <Button Grid.Column="1"
                      Content="浏览"
                      Margin="12,0,0,0"
                      Width="100"
                      Height="40"
                      Click="BrowseButton_Click"
                      Background="#1D4ED8"
                      BorderBrush="#1D4ED8" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="3" Margin="0,18,0,0" Background="#111827" CornerRadius="10" Padding="16">
          <StackPanel>
            <TextBlock Foreground="#E2E8F0" FontSize="13" Text="- 安装前自动关闭正在运行的教师端进程" />
            <TextBlock Margin="0,6,0,0" Foreground="#E2E8F0" FontSize="13" Text="- 自动清理旧版本并执行覆盖安装" />
            <TextBlock Margin="0,6,0,0" Foreground="#E2E8F0" FontSize="13" Text="- 自动创建桌面和开始菜单快捷方式" />
          </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" VerticalAlignment="Center">
          <TextBlock Name="StatusText"
                     Text="准备开始安装"
                     Foreground="#BFDBFE"
                     FontSize="14" />
          <ProgressBar Name="InstallProgress"
                       Height="8"
                       Margin="0,14,0,0"
                       Minimum="0"
                       Maximum="100"
                       Value="0"
                       Foreground="#3B82F6"
                       Background="#1E293B" />
        </StackPanel>

        <Grid Grid.Row="5" Margin="0,18,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <CheckBox Name="LaunchCheckBox"
                    Grid.Column="0"
                    Content="安装完成后立即启动 LumeSync Teacher"
                    VerticalAlignment="Center"
                    IsChecked="True"
                    Foreground="#CBD5E1" />

          <Button Name="InstallButton"
                  Grid.Column="1"
                  Content="开始安装"
                  Width="120"
                  Height="42"
                  Margin="0,0,12,0"
                  Click="InstallButton_Click" />

          <Button Name="DoneButton"
                  Grid.Column="2"
                  Content="完成"
                  Width="120"
                  Height="42"
                  Visibility="Collapsed"
                  Click="DoneButton_Click"
                  Background="#059669"
                  BorderBrush="#059669" />
        </Grid>
      </Grid>
    </Grid>
  </Border>
</Window>
