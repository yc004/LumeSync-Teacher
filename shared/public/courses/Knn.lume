// K-means 演示：分组颜色配置
const KMEANS_COLORS = [
    { bg: '#3b82f6', cls: 'bg-blue-500', name: '第1组' },
    { bg: '#f43f5e', cls: 'bg-rose-500', name: '第2组' },
    { bg: '#10b981', cls: 'bg-emerald-500', name: '第3组' },
