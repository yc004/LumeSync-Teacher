    { bg: '#8b5cf6', cls: 'bg-violet-500', name: '第5组' },
];

// K-means 演示：初始数据点生成器
const makeKMeansPoints = () => [
    { x: 18, y: 22 }, { x: 25, y: 30 }, { x: 20, y: 28 }, { x: 28, y: 20 }, { x: 22, y: 35 },
    { x: 72, y: 20 }, { x: 78, y: 28 }, { x: 65, y: 22 }, { x: 80, y: 18 }, { x: 70, y: 30 },
    { x: 46, y: 74 }, { x: 52, y: 80 }, { x: 55, y: 70 }, { x: 42, y: 72 }, { x: 58, y: 78 },
    { x: 35, y: 50 }, { x: 45, y: 45 }, { x: 40, y: 55 }, { x: 50, y: 40 }, { x: 55, y: 52 },
].map(p => ({ ...p, cluster: -1 }));

// K-means 演示：初始圆心生成器
const makeKMeansCentroids = (k = 3) => {
    const centers = [];
    for (let i = 0; i < k; i++) {
        centers.push({ x: 20 + Math.random() * 60, y: 20 + Math.random() * 60 });
    }
    return centers;
};

